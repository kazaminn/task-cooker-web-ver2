rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /tests/{docId} {
      allow read, write: if true;
    }

    // ヘルパー関数: 認証済みか確認
    function isAuthenticated() {
      return request.auth != null;
    }

    // ヘルパー関数: プロジェクトのメンバーか確認
    // get() はコストが高いため、可能な限り resource (既存データ) を参照します
    function isProjectMember(projectId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
    }

    // ユーザープロファイル
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // チーム
    match /teams/{teamId} {
      // メンバーなら閲覧可能
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberIds;
      // 誰でも作成可能（作成後は ownerId が一致する必要がある）
      allow create: if isAuthenticated();
      // オーナーのみ更新・削除可能
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    // collectionGroup クエリ用ルール
    // tasks, activities は collectionGroup でクロスプロジェクト検索される
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/activities/{activityId} {
      allow read: if isAuthenticated();
    }

    // プロジェクトおよびサブコレクション
    match /projects/{projectId} {
      // プロジェクト本体の権限
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.memberIds;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.memberIds;
      allow update, delete: if isAuthenticated() &&
        request.auth.uid in resource.data.memberIds;

      // カウンター（displayId 採番用）
      match /counters/{counterId} {
        allow read, write: if isProjectMember(projectId);
      }

      // タスク（サブコレクション）
      match /tasks/{taskId} {
        allow read, write: if isProjectMember(projectId);

        // コメント（タスクのサブコレクション）
        match /comments/{commentId} {
          allow read, write: if isProjectMember(projectId);
        }
      }

      // アクティビティ（サブコレクション）
      match /activities/{activityId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
      }

      // Mixes（サブコレクション）
      match /mixes/{mixId} {
        allow read, write: if isProjectMember(projectId);

        // Mixes 内の投稿
        match /posts/{postId} {
          allow read, write: if isProjectMember(projectId);
        }
      }
    }
  }
}
