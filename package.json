{
  "name": "task-cooker-web",
  "version": "1.0.0",
  "description": "todo app using a cooking metaphor for task statuses.",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "vite --mode development",
    "preview": "vite preview",
    "build": "tsc -b && vite build --mode production",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint .",
    "lint:strict": "eslint . --no-warn-ignored --max-warnings 0",
    "test": "vitest --pass-with-no-tests --run --mode test",
    "test:firestore-rules": "pnpm exec vitest run --config vitest.rules.config.ts --mode test",
    "test:watch": "vitest --pass-with-no-tests --mode test",
    "test:coverage": "vitest --pass-with-no-tests --run --mode test --coverage",
    "test:related": "bash scripts/test-related.sh",
    "ai:check": "pnpm format && pnpm lint:fix && pnpm typecheck && pnpm test:related",
    "ai:verify": "pnpm format:check && pnpm lint:ci && pnpm typecheck && pnpm test:related",
    "ci": "pnpm format:check && pnpm lint:ci && pnpm typecheck && pnpm test",
    "check": "pnpm ci",
    "prepare": "husky",
    "precommit": "lint-staged --concurrent false",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "test-storybook",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "emulators": "firebase emulators:start --import=./firebase-data --export-on-exit",
    "seed": "cross-env FIRESTORE_EMULATOR_HOST=localhost:8080 AUTH_EMULATOR_HOST=localhost:9099 tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@internationalized/date": "^3.12.0",
    "@tanstack/react-query": "^5.90.20",
    "@uiw/react-md-editor": "^4.0.11",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "firebase": "^12.8.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-react-aria-components": "^2.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-themes": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "axe-core": "^4.11.1",
    "chromatic": "^15.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.10",
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^15.11.0",
    "globals": "^17.2.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.2.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
